# Copy this file to ".env" and fill it in before running docker compose.

# The domain the server will be reachable on (must point at this machine's
# public IP with an A record). Caddy fetches the HTTPS certificate for it.
LUMA_DOMAIN=sync.example.com

# Account registration is OPEN by default: anyone who can reach the server
# and knows its address can create an account. Once everyone you want has an
# account, set this to "false" to stop new sign-ups (existing accounts keep
# working). On a public server, note that open registration lets strangers
# use up to 3 GB of storage each.
LUMA_ALLOW_REGISTRATION=true

# Storage quota per account, in bytes. Default: 3 GiB.
LUMA_QUOTA_BYTES=3221225472

# Maximum size of a single uploaded snapshot, in bytes. Default: 256 MiB.
LUMA_MAX_BLOB_BYTES=268435456

# How long a login stays valid on a device, in days.
LUMA_TOKEN_TTL_DAYS=90

# Which web origins may call the API (only matters for the web build of the
# app). "*" is safe here because auth uses bearer tokens, not cookies.
LUMA_CORS_ORIGIN=*
