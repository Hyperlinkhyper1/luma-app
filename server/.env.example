# Copy this file to ".env" and fill it in before running docker compose.

# The domain the server will be reachable on (must point at this machine's
# public IP with an A record). Caddy fetches the HTTPS certificate for it.
LUMA_DOMAIN=sync.example.com

# Required — Caddy uses this to get its HTTPS certificate via a Cloudflare
# DNS-01 challenge instead of the default HTTP-01/TLS-ALPN-01. Needed
# whenever LUMA_DOMAIN's DNS is proxied through Cloudflare (orange cloud)
# or routed via a Cloudflare Tunnel, since Cloudflare's edge intercepts
# the default challenges before they reach this machine — common for a
# home server with no port forwarding. DNS-01 only needs this token to
# create a TXT record, no inbound connectivity required. NOT the same as
# a Cloudflare Tunnel token — create one at
# https://dash.cloudflare.com/profile/api-tokens using the "Edit zone DNS"
# template, scoped to this domain's zone.
CLOUDFLARE_API_TOKEN=

# Account registration is OPEN by default: anyone who can reach the server
# and knows its address can create an account. Once everyone you want has an
# account, set this to "false" to stop new sign-ups (existing accounts keep
# working). Storage quota is set by plan, not here — see kPlanQuotaBytes in
# lib/store.dart (10/25/50 MB for core/orbit/nova); grant plans to accounts
# from the /admin dashboard's Products tab.
LUMA_ALLOW_REGISTRATION=true

# Maximum size of a single uploaded snapshot, in bytes. Default: 256 MiB.
LUMA_MAX_BLOB_BYTES=268435456

# How long a login stays valid on a device, in days.
LUMA_TOKEN_TTL_DAYS=90

# Which web origins may call the API (only matters for the web build of the
# app). "*" is safe here because auth uses bearer tokens, not cookies.
LUMA_CORS_ORIGIN=*

# --- Email verification -----------------------------------------------------

# New accounts must click a link emailed to them before they can sign in.
# Set to "false" to skip verification entirely (e.g. closed/trusted
# deployments that don't want to configure SMTP).
LUMA_REQUIRE_EMAIL_VERIFICATION=true

# How long a verification link stays valid, in hours.
LUMA_VERIFICATION_TTL_HOURS=24

# The public URL this server is reachable at, used to build the link in the
# verification email (e.g. https://sync.example.com). Should match LUMA_DOMAIN.
LUMA_PUBLIC_URL=https://sync.example.com

# SMTP credentials used to send verification email. Works with any standard
# provider (Postmark, SES, Mailgun, Fastmail, a private relay, etc). If
# LUMA_SMTP_HOST is left blank, verification links are logged to the server's
# console instead of emailed — useful for local testing only.
LUMA_SMTP_HOST=
LUMA_SMTP_PORT=587
LUMA_SMTP_USER=
LUMA_SMTP_PASS=
# Set to "true" for implicit TLS (usually port 465); leave "false" for
# STARTTLS (usually port 587).
LUMA_SMTP_SSL=false
# Address (and optional display name) verification email is sent from.
LUMA_SMTP_FROM=noreply@sync.example.com
LUMA_SMTP_FROM_NAME=Luma

# --- Admin dashboard ---------------------------------------------------------

# Enables the operator-only /admin, /admin/users, and /admin/stats endpoints,
# which list all registered accounts and their storage usage (metadata only —
# never blob contents). Pass this value via the X-Admin-Key header, or as
# ?key=... when opening /admin in a browser. Leave blank to disable these
# endpoints entirely (they 404 instead of being reachable unauthenticated).
# Generate one with e.g. `openssl rand -hex 32`.
LUMA_ADMIN_KEY=

# --- Groceries (supermarket-db) control panel ---------------------------------

# The admin dashboard's "Control panel" tab can reload/update the groceries
# product database by proxying to the supermarket-db API (see supermarket-db/
# at the repo root). Set this to the same value as ADMIN_KEY in the groceries
# server's .env. Leave blank to hide the feature.
LUMA_GROCERIES_ADMIN_KEY=

# Where the groceries API lives. Only set this if yours runs somewhere other
# than the default.
#LUMA_GROCERIES_URL=https://groceries.luma-app.cc

# --- AI provider keys ---------------------------------------------------------

# Optional. When set, every signed-in user's app can chat with Mistral
# ("Luma" in the app's UI) through this server — POST /api/v1/ai/mistral/chat
# proxies the request to Mistral using this key server-side, so the key
# itself is never sent to any client, only used to make the call on their
# behalf. This means every account on this server shares one Mistral bill;
# there's no per-user usage cap beyond the general API rate limit. Get a key
# from https://console.mistral.ai. Leave blank to keep the old per-device
# manual key entry as the only option.
LUMA_MISTRAL_API_KEY=

# Optional, only used together with LUMA_MISTRAL_API_KEY. A Mistral Agents
# API agent id (looks like "ag:...", created at https://console.mistral.ai
# under Agents). When set, chats proxied through this server use that hosted
# agent (its model, instructions, etc.) unless the user selected their own
# agent profile in the app. Leave blank to use the plain default model.
LUMA_MISTRAL_AGENT_ID=

# Optional. A Google AI Studio API key (https://aistudio.google.com/apikey).
# When set, signed-in users get the app's "Luma AI" provider with three
# modes — Aurora 1.0 / Nebula 1.0 / Pulsar 1.0 (Gemini flash-lite / flash /
# pro under the hood). Chats are proxied server-side so the key never
# reaches any client, and each user is token-metered: 7,500 tokens per
# rolling 5 hours and 40,000 per rolling week (shown to users only as a
# percentage). Luma Support (the Mistral key above) has its own separate
# limit of 15 messages per day. Limits live in server/lib/api.dart
# (kAiTokens5h / kAiTokensWeek / kSupportMessagesPerDay).
LUMA_GOOGLE_API_KEY=
