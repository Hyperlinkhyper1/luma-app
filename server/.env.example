# Copy this file to ".env" and fill it in before running docker compose.

# The domain the server will be reachable on (must point at this machine's
# public IP with an A record). Caddy fetches the HTTPS certificate for it.
LUMA_DOMAIN=sync.example.com

# Account registration is OPEN by default: anyone who can reach the server
# and knows its address can create an account. Once everyone you want has an
# account, set this to "false" to stop new sign-ups (existing accounts keep
# working). Storage quota is set by plan, not here — see kPlanQuotaBytes in
# lib/store.dart (10/25/50 MB for core/orbit/nova); grant plans to accounts
# from the /admin dashboard's Products tab.
LUMA_ALLOW_REGISTRATION=true

# Maximum size of a single uploaded snapshot, in bytes. Default: 256 MiB.
LUMA_MAX_BLOB_BYTES=268435456

# How long a login stays valid on a device, in days.
LUMA_TOKEN_TTL_DAYS=90

# Which web origins may call the API (only matters for the web build of the
# app). "*" is safe here because auth uses bearer tokens, not cookies.
LUMA_CORS_ORIGIN=*

# --- Email verification -----------------------------------------------------

# New accounts must click a link emailed to them before they can sign in.
# Set to "false" to skip verification entirely (e.g. closed/trusted
# deployments that don't want to configure SMTP).
LUMA_REQUIRE_EMAIL_VERIFICATION=true

# How long a verification link stays valid, in hours.
LUMA_VERIFICATION_TTL_HOURS=24

# The public URL this server is reachable at, used to build the link in the
# verification email (e.g. https://sync.example.com). Should match LUMA_DOMAIN.
LUMA_PUBLIC_URL=https://sync.example.com

# SMTP credentials used to send verification email. Works with any standard
# provider (Postmark, SES, Mailgun, Fastmail, a private relay, etc). If
# LUMA_SMTP_HOST is left blank, verification links are logged to the server's
# console instead of emailed — useful for local testing only.
LUMA_SMTP_HOST=
LUMA_SMTP_PORT=587
LUMA_SMTP_USER=
LUMA_SMTP_PASS=
# Set to "true" for implicit TLS (usually port 465); leave "false" for
# STARTTLS (usually port 587).
LUMA_SMTP_SSL=false
# Address (and optional display name) verification email is sent from.
LUMA_SMTP_FROM=noreply@sync.example.com
LUMA_SMTP_FROM_NAME=Luma

# --- Admin dashboard ---------------------------------------------------------

# Enables the operator-only /admin, /admin/users, and /admin/stats endpoints,
# which list all registered accounts and their storage usage (metadata only —
# never blob contents). Pass this value via the X-Admin-Key header, or as
# ?key=... when opening /admin in a browser. Leave blank to disable these
# endpoints entirely (they 404 instead of being reachable unauthenticated).
# Generate one with e.g. `openssl rand -hex 32`.
LUMA_ADMIN_KEY=
