# MySQL connection. DB_HOST=127.0.0.1 is for running node directly on your
# own machine; docker-compose.yml overrides it to "mysql" (the service name)
# automatically, so leave it as-is even when deploying with Docker.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=luma
DB_PASSWORD=changeme
DB_NAME=luma_supermarkets
DB_CONNECTION_LIMIT=10

NODE_ENV=development

# HTTP API (src/api/server.js)
PORT=3000

# --- Only used by docker-compose.yml (Linux server deployment) ---

# Root password for the MySQL container. Only DB_USER/DB_PASSWORD above are
# used day-to-day; this just bootstraps the database and user on first run.
MYSQL_ROOT_PASSWORD=changeme-too

# Token for the Cloudflare Tunnel connector (cloudflared), from the Zero
# Trust dashboard: Networks → Tunnels → your tunnel → "Docker" install
# command. Public hostname routing (e.g. groceries.luma-app.cc → api:3000)
# is configured there too, not in this repo.
CLOUDFLARE_TUNNEL_TOKEN=
